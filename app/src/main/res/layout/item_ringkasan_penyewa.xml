<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/bg_white">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="14dp">
        <!--  Profile avatar  -->
        <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_profile_placeholder" android:background="@drawable/circle_profile" android:padding="3dp" android:layout_marginEnd="12dp"/>
        <!--  Name + Kamar  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/tvNamaPenghuni" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Username penyewa" android:textColor="@color/navy_dark" android:textSize="14sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvNoKamar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nomor Kamar" android:textColor="@color/text_medium" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
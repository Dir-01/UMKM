<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_header_bottom_rounded"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:text="Tambahkan\nKamar Baru"
            android:textAlignment="center"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginEnd="32dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_bottom_bar_dark"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/btn_simpan_kamar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_pemilik"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Simpan Kamar Baru"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textSize="18sp"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/bottom_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama/No.Kamar"
                android:textColor="@color/colorPrimary"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_nama_kamar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card_outline_black"
                android:hint="Contoh: Kamar 06"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_dark"
                android:textColorHint="#757575"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="24dp"/>

            <!-- 👇 TAMBAHAN UNTUK TIPE KAMAR 👇 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Tipe Kamar"
                android:textColor="@color/colorPrimary"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinner_tipe_kamar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card_outline_black"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="24dp"/>
            <!-- 👆 AKHIR TAMBAHAN TIPE KAMAR 👆 -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga Sewa Kamar"
                android:textColor="@color/colorPrimary"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_harga_kamar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card_outline_black"
                android:hint="Contoh: 1000000 (Tanpa titik)"
                android:inputType="number"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_dark"
                android:textColorHint="#757575"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Status Awal"
                android:textColor="@color/colorPrimary"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinner_status_kamar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card_outline_black"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <!-- Tambahkan ini di dalam LinearLayout ScrollView, setelah Spinner Status -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Foto Kamar"
                android:textColor="@color/colorPrimary"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <ImageView
                android:id="@+id/iv_preview_kamar"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_card_outline_black"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_kamar"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btn_pilih_foto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih Foto dari Galeri"
                android:backgroundTint="@color/text_dark"
                android:textColor="@color/text_white"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
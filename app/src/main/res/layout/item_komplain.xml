<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="14dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/bg_white">
    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="14dp">
        <!--  Profile + Info Row  -->
        <LinearLayout android:id="@+id/infoRow" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:id="@+id/ivProfile" android:layout_width="52dp" android:layout_height="52dp" android:src="@drawable/ic_profile_placeholder" android:background="@drawable/circle_profile" android:padding="4dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nama Penghuni : " android:textColor="@color/text_dark" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvNama" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_medium" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No. Kamar : " android:textColor="@color/text_dark" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvNoKamar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_medium" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Keluhan : " android:textColor="@color/text_dark" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvKeluhan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_medium" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status : " android:textColor="@color/text_dark" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_medium" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <!--  Update Status Button  -->
        <Button android:id="@+id/btnUpdateStatus" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Update Status" android:textColor="@color/text_white" android:textSize="12sp" android:background="@drawable/bg_btn_dark_blue_small" android:layout_below="@id/infoRow" android:layout_alignParentEnd="true" android:layout_marginTop="10dp" android:paddingHorizontal="12dp" android:drawableStart="@drawable/ic_phone" android:drawablePadding="6dp"/>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_outline"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/img_kamar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_kamar_1" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tv_label_nomor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nomor Kamar"
                android:fontFamily="serif"
                android:textSize="14sp"
                android:textColor="@color/text_dark"/>

            <TextView
                android:id="@+id/tvTipeKamar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipe 1"
                android:fontFamily="serif"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvHargaKamar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp. 700.000/Bulan"
                android:fontFamily="serif"
                android:textSize="16sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="4dp"/>

            <!-- INI TAMBAHANNYA AGAR TIDAK ERROR LAGI -->
            <TextView
                android:id="@+id/tvStatusKamar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tersedia"
                android:fontFamily="serif"
                android:textSize="14sp"
                android:textStyle="italic"
                android:textColor="@color/btn_gold" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>